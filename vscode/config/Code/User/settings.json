{
    "[git-commit]": {
        "editor.rulers": [
            72,
            80
        ],
        "rewrap.autoWrap.enabled": true,
        "rewrap.wrappingColumn": 80
    },
    "[markdown]": {
        "files.trimTrailingWhitespace": false
    },
    "chat.commandCenter.enabled": false,
    "cSpell.enabledFileTypes": {
        "*": false,
        "git-commit": true,
        "markdown": true,
        "restructuredtext": true,
        "scminput": true
    },
    "cSpell.language": "en,de-DE",
    "cSpell.useGitignore": false,
    "dev.containers.defaultExtensionsIfInstalledLocally": [
        "eriklynd.json-tools",
        "mhutchie.git-graph",
        "ms-azuretools.vscode-docker",
        "redhat.vscode-yaml",
        "streetsidesoftware.code-spell-checker"
    ],
    "dev.containers.defaultFeatures": {
        "ghcr.io/devcontainers-contrib/features/zsh-plugins:0": {
            "omzPlugins": "https://github.com/romkatv/powerlevel10k.git"
        },
        "ghcr.io/devcontainers/features/common-utils:2": {
            "configureZshAsDefaultShell": true,
            "installOhMyZsh": true,
            "installOhMyZshConfig": false,
            "installZsh": true,
            "upgradePackages": false
        },
        "ghcr.io/stuartleeks/dev-container-features/shell-history:0": {}
    },
    "dev.containers.gitCredentialHelperConfigLocation": "none",
    "dotfiles.repository": "https://github.com/schrank251/dotfiles.git",
    "dotfiles.targetPath": "~/.dotfiles",
    "editor.scrollbar.ignoreHorizontalScrollbarInContentHeight": true,
    "editor.scrollBeyondLastLine": false,
    "editor.tabSize": 8,
    "extensions.ignoreRecommendations": true,
    "files.associations": {
        "log.*": "log"
    },
    "files.insertFinalNewline": true,
    "files.trimTrailingWhitespace": true,
    "git.inputValidation": true,
    "git.inputValidationLength": 80,
    "git.inputValidationSubjectLength": 72,
    "git.openRepositoryInParentFolders": "never",
    "git.showActionButton": {
        "commit": false,
        "publish": false,
        "sync": false
    },
    "git.suggestSmartCommit": false,
    "logFileHighlighter.customPatterns": [
        {
            "foreground": "#56B6C2",
            "pattern": "INFO|NOTE|DEBUG"
        },
        {
            "foreground": "#56B6C2",
            "pattern": "starting|start|loading|booting",
            "patternFlags": "i"
        },
        {
            "foreground": "#C678DD",
            "pattern": "reading|\\bREAD\\b",
            "patternFlags": "i"
        },
        {
            "foreground": "#98C379",
            "pattern": "\\bOK\\b",
            "patternFlags": "i"
        },
        {
            "foreground": "#E5C07B",
            "pattern": "warning|warn|unknown|unable to|unable|not found|disabled|disable|deprecated|could not",
            "patternFlags": "i"
        },
        {
            "foreground": "#E06C75",
            "pattern": "\\bNOT\\b|\\bNO\\b|fatal|failure|failed|fail|errors|error",
            "patternFlags": "i"
        }
    ],
    "redhat.telemetry.enabled": false,
    "remote-explorer.foldersSortOrder": "alphabetical",
    "search.useIgnoreFiles": false,
    "telemetry.telemetryLevel": "off",
    "terminal.integrated.allowChords": false,
    "terminal.integrated.localEchoEnabled": "off",
    "terminal.integrated.persistentSessionReviveProcess": "never",
    "terminal.integrated.scrollback": 10000,
    "terminal.integrated.showExitAlert": false,
    "workbench.colorCustomizations": {
        "diffEditor.insertedLineBackground": "#00ff0033",
        "diffEditor.insertedTextBackground": "#00ff0033",
        "diffEditor.removedLineBackground": "#ff000033",
        "diffEditor.removedTextBackground": "#ff000033"
    },
    "workbench.colorTheme": "One Dark Pro",
    "workbench.editor.empty.hint": "hidden",
    "workbench.list.horizontalScrolling": true,
    "workbench.startupEditor": "none"
}
